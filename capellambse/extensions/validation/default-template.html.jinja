{# Summary table #}
<h2>Assessment Summary</h2>
{% set object_types = ["Capability", "SystemFunction", "ComponentExchange", "FunctionalExchange"] %}
<table>
  <thead>
    <tr>
      <th rowspan="2">Object type</th>
      <th rowspan="2">Total objects</th>
      <th colspan="3">Compliance to applicable modeling rules</th>
    </tr>
    <tr>
      <th>REQUIRED</th>
      <th>RECOMMENDED</th>
      <th>SUGGESTED</th>
    </tr>
  </thead>
  <tbody>
    {% for obj_type in object_types %}
      {% set objects = model.search(obj_type, below=model.sa) | sort(attribute="name") %}
      {% set categories = ["REQUIRED", "RECOMMENDED", "SUGGESTED"] %}
      {% set total = objects | count %}
      <tr>
        <th>{{ obj_type }}</th>
        <td>{{ total }}</td>
        {% for category in categories %}
          {# we will count here for every object of a type and category, how many rules applied to it and to how many it complied, then show a sum of those values for all objects of type #}

          {% set rules = results.by_category(category).by_type(obj_type) %}
          {% set passed, total = rules.get_passed_and_total() %}
          {% set compliance = ((passed / total * 100)|round(1) if total > 0 else "—") | string + "% ({} / {})".format(passed, total) %}
          <td>{{ compliance }}</td>
        {% endfor %}
    {% endfor %}
</table>

<h2>Object Compliance Analysis</h2>
<p>This section evaluates the selected objects' adherence to modeling rules. If an object needs additional work or has
  potential for improvement, we provide actionable suggestions to enhance its compliance.</p>

{% set object_types = ["Capability", "SystemFunction", "ComponentExchange", "FunctionalExchange"] %}
{% for obj_type in object_types %}
<h3>{{ obj_type }}</h3>
{% set objects = model.search(obj_type, below=model.sa) | sort(attribute="name") %}

<table>
  <thead>
    <tr>
      <th>{{ obj_type }}</th>
      <th>Rule Category</th>
      <th>Compliance (%)</th>
      <th>Improvement Suggestions (Actions)</th>
    </tr>
  </thead>
  <tbody>
    {% set objects = objects | sort(attribute="name") %}
    {% for object in objects %}
      {% set categories = [] %}
      {% for category in ["REQUIRED", "RECOMMENDED", "SUGGESTED"] %}
        {% set rules = results.by_category(category).by_uuid(object.uuid) %}
        {% set passed = rules.items() | selectattr('1.value', 'equalto', true) | list | count %}
        {% set total = rules | count %}
        {% set compliance = ((passed / total * 100)|round(1) if total > 0 else "—") | string + "% ({} / {})".format(passed, total) %}
        {% set actions = [] %}
        {% for rule in rules.items() | selectattr('1.value', 'equalto', false) | map("first") | list %}
          {% for action in rule.actions %}
            {% set _ = actions.append([rule.id, action]) %}
          {% endfor %}
        {% endfor %}
        {% if rules | count > 0 %}
          {% set _ = categories.append([category, compliance, actions]) %}
        {% endif %}
      {% endfor %}

      {% if categories | count == 0 %}
        {# no rules applied to the object #}
        <tr>
          <th>{{ object.name }}</th>
          <td colspan="3">No rules applied</td>
        </tr>
      {% else %}
        {% for category, compliance, actions in categories %}
          <tr>
            {# only show next line if it is first loop pass #}
            {% if loop.first %}
              <th rowspan="{{ categories | count }}">{{ object.name }}</th>
            {% endif %}
            <td><b class="rule-{{ category |lower }}">{{ category }}</b></td>
            <td>{{ compliance }}</td>
            <td>
              {% if actions %}
                <ul>
                  {% for rule_id, action in actions %}
                    <li><a href="#{{ rule_id }}">{{ action }}</a></li>
                  {% endfor %}
                </ul>
              {% else %}
                <em>No action required</em>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      {% endif %}
    {% endfor%}
  </tbody>
</table>
{%- endfor %}

