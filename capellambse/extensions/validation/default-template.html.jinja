{%- set results = model.validate() %}

<title>System Analysis Layer: Modeling Rules Compliance Report</title>
</head>
<body>
<h1>System Analysis Layer: Modeling Rules Compliance Report</h1>
<p>
  The report provides an assessment of adherence to Modeling Rules and Best Practices by the contents of the System Analysis model layer.
</p>

{% macro show_compliance_score(passed, total) %}
  {# This macro shows compliance score and conditionally colors it: if value is below 30% it will be red, between 30 and 70 % it will be orange, above 70 % green; #}
  {# It is also possible that total is 0, in this case it will return "not applicable" in gray color #}
  {% if total > 0 %}
    {% set compliance_score = (passed / total * 100)|round(1) %}
    {% set compliance = compliance_score | string + "%" %}
    {% set color = "#bc2604" if compliance_score < 30 else ("#ae930d" if compliance_score < 70 else "#0a6600") %}
    <span style="color:{{ color }}">{{ compliance }} <small>{{ "({} / {})".format(passed, total) }}</small></span>
  {% else %}
    <span style="color:#ccc">not applicable</span>
  {% endif %}
{% endmacro %}

