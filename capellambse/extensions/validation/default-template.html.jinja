}

thead th {
  background-color: #f2f2f2;
  position: sticky;
  top: 0;
  z-index: 10;
  font-weight: bold;
  text-transform: uppercase;
}

tbody th {
  background-color: #f2f2f2;
  position: sticky;
  left: 0;
  z-index: 5;
  border-right: 1px solid #ccc;
}

td ul {
  margin: 0;
  padding-left: 1em;
}

tr:nth-child(even) { background-color: #f8f8f8; }


