/* Apply Arial font style to the entire page */
html, body {
  font-family: Arial, "Helvetica Neue", Helvetica, sans-serif;
  font-size: 16px; /* Adjust this value according to your preference */
  line-height: 1.5; /* Adjust this value for better readability */
  color: #333; /* Adjust text color according to your preference */
}

body { margin: 1em; }

/* Hyperlink styles */
a {
  color: #0066cc; /* Adjust the link color to your preference */
  text-decoration: none; /* Remove the default underline */
  transition: color 0.3s ease; /* Add smooth color transition */
}

/* Hyperlink hover styles */
a:hover {
  color: #004799; /* Adjust the hover color to your preference */
  text-decoration: underline; /* Add underline on hover */
}


/* General table styles */
table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  margin-bottom: 1rem;
  border: 1px solid #ccc; /* Outer border */
}

/* Header and rows styles */
th, td {
  padding: 0.75rem;
  text-align: left;
  position: relative;
}

/* Header background color and sticky position */
thead th {
  background-color: #f2f2f2;
  position: sticky;
  top: 0;
  z-index: 10;
}

/* First column header background color and sticky position */
tbody th {
  background-color: #f2f2f2;
  position: sticky;
  left: 0;
  z-index: 5;
}

/* Header text styles */
th {
  font-weight: bold;
  text-transform: uppercase;
}

/* Borders for table cells */
td {
  border-top: 1px solid #ccc;
  border-bottom: 1px solid #ccc;
}

th {
  border-top: 1px solid #ccc;
  border-bottom: 1px solid #ccc;
}

/* First column header border */
tbody th {
  border-right: 1px solid #ccc;
}

/* Striped row colors */
tr:nth-child(even) {
  background-color: #f8f8f8;
}

tr:hover {
  background-color: #e8e8e8;
}

</style>

