{# Summary table #}
<h2>Assessment Summary</h2>
{% set object_types = ["Capability", "SystemComponent", "SystemFunction", "ComponentExchange", "FunctionalExchange"] %}
<table>
  <thead>
    <tr>
      <th rowspan="2">Reviewed objects</th>
      <th rowspan="2" width="90px">Total objects</th>
      <th colspan="3">Compliance to applicable modeling rules</th>
    </tr>
    <tr>
      <th>REQUIRED</th>
      <th>RECOMMENDED</th>
      <th>SUGGESTED</th>
    </tr>
  </thead>
  <tbody>
    {% for obj_type in object_types %}
      {% set objects = model.search(obj_type, below=model.sa) | sort(attribute="name") %}
      {% set total = objects | count %}
      <tr>
        <th><a href="#{{ obj_type }}">{{ obj_type }}</a></th>
        <td>{{ total }}</td>
        {% for category in CATEGORIES %}
          {% set result = results.by_category(category).by_type(obj_type) %}
          {% set passed, total_checks = get_passed_and_total(result, type=obj_type) %}
          <td>
            {{ show_compliance_score(passed, total_checks) }}
          </td>
        {% endfor %}
    {% endfor %}
</table>

<h2>Object Compliance Analysis</h2>
<p>This section evaluates the selected objects' adherence to modeling rules. If an object needs additional work or has
  potential for improvement, we provide actionable suggestions to enhance its compliance.</p>

{% for obj_type in object_types %}
<h3 id="{{ obj_type }}">{{ obj_type }}</h3>
{%- set objects = model.search(obj_type, below=model.sa) | sort(attribute="name") %}
{%- for object in objects if results.by_value(False).by_uuid(object.uuid) %}
  {%- if loop.first %}
    <table>
      <thead>
        <tr>
          <th width="250px">{{ obj_type }}</th>
          <th width="140px">Rule Category</th>
          <th width="140px">Compliance (%)</th>
          <th>Improvement Suggestions (Actions)</th>
        </tr>
      </thead>
      <tbody>
    {%- endif %}
    {%- set categories = [] %}
    {%- for category in CATEGORIES %}
      {%- set rules = results.by_value(False).by_category(category).by_uuid(object.uuid) %} 
      {%- set passed, total = get_passed_and_total(rules) %}
      {%- set actions = [] %}
      {%- for rule, result in rules.items() %}
        {%- set _ = actions.append([rule.id, rule.action]) %}
      {%- endfor %}
      {%- if rules | count > 0 %}
        {%- set _ = categories.append([category, passed, total, actions]) %}
      {%- endif %}
    {%- endfor %}

      {%- for category, passed, total, actions in categories %}
        <tr>
          {# only show next line if it is first loop pass #}
          {% if loop.first %}
            <th rowspan="{{ categories | count }}">{{ object.name }}</th>
          {% endif %}
          <td><b class="rule-{{ category |lower }}">{{ category }}</b></td>
          <td>{{ show_compliance_score(passed, total) }}</td>
          <td>
            {% if actions %}
              <ul>
                {% for rule_id, action in actions %}
                  <li><a href="#{{ rule_id }}">{{ action }}</a></li>
                {% endfor %}
              </ul>
            {% else %}
              <em>No action required</em>
            {% endif %}
          </td>
        </tr>
      {%- endfor %}
{%- if loop.last %}
  </tbody>
</table>
{%- endif %}
{%- else %}
  <p>No rules apply to {{ obj_type }} objects or no objects of interest found in the selected layer.</p>
{%- endfor%}

{# compliant objects section #}
  {% set categories_of_interest = [] %}
  {% for category in CATEGORIES %}
    {% set objects_of_interest = [] %}
    {% for object in objects if results.by_category(category).by_uuid(object.uuid) and not results.by_category(category).by_value(False).by_uuid(object.uuid) %}
      {% set _ = objects_of_interest.append(object) %}
    {% endfor %}
    {% if objects_of_interest | count > 0 %}
      {% set _ = categories_of_interest.append([category, objects_of_interest])%}
    {% endif %}
  {%endfor%}
  {% for category, objects_of_interest in categories_of_interest %}
    {% if loop.first %}
      <p>These objects comply completely to at least one rule category completely</p>
    {% endif %}
    <p>All 
      {{ model.validation.rules[category].by_type(obj_type) | count}} 
      <strong class="rule-{{category.name | lower}}">{{category}}</strong> rules were met by the following {{ objects_of_interest | count }} object(s):</b>
    {{ objects_of_interest | join("; ", attribute="name")}}
    </p>
  {% endfor %}
{%- endfor %} {# end of object_types loop #}

<h2>Validation results by rule</h2>
<!-- TODO filter by applicability to this layer -->
<table>
<thead>
  <tr>
    <th width="160px">Rule ID
    <th>Definition
    <th width="100px">Passed
    <th>Failed
  <tbody>
    {%- for rule, objs in results.items() %}
    {%- set failed = results.by_value(false)[rule] %}
    {% set total = objs | count %}
    {% set passed = total - failed|count %}
    <tr>
      <th id="{{rule.id}}">{{ rule.id }}<br>
      <span class="rule-{{ rule.category.name|lower }}">{{ rule.category.name }}</span>
      <p style="color:#999">Applies to: {{ rule.types |map(attribute='__name__') | list | join(", ") }}</p>

      <td>
        <strong>{{ rule.name }}</strong><br>
        {{ rule.rationale }} {% if rule.url %}<a href="{{ rule.url }}">More info</a>{% endif %}
        <p><b>Recommended action:</b><br>{{ rule.action }}</p>

      <td>{{ show_compliance_score(passed, total) }}
      <td>
        {%- for result in failed.values() | sort(attribute="name") %}
        {%- set obj = model.by_uuid(result.uuid) %}
        {%- if loop.first %}
        <ul>
        {%- endif %}
          <li>
            <a href="#{{obj.uuid}}">
              {{ obj.name|e }}
              <span class="small">({{ obj.uuid }})</span>
            </a>
        {%- else %}
        All {{ objs | count}} object(s) comply to this rule
        {%- endfor %}
    {%- endfor %}
</table>

</body>
</html>
