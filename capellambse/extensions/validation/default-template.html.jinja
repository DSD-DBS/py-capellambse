/* General styles */
html, body {
  font-family: Arial, "Helvetica Neue", Helvetica, sans-serif;
  font-size: 16px;
  line-height: 1.5;
  color: #333;
}

body { margin: 1em; }

/* Hyperlink styles */
a {
  color: #0066cc;
  text-decoration: none;
  transition: color 0.3s ease;
}

a:hover {
  color: #004799;
  text-decoration: underline;
}

/* Table styles */
table {
  table-layout: fixed; /* This ensures that the table cells have fixed widths */
  width: 100%; /* Ensures the table takes up the full width of its container */
  border-collapse: separate;
  border-spacing: 0;
  margin-bottom: 1rem;
  border: 1px solid #ccc;
}

th, td {
  padding: 0.75rem;
  text-align: left;
  position: relative;
  border-top: 1px solid #ccc;
  border-bottom: 1px solid #ccc;
  min-width: 100px; /* You can adjust the minimum width to fit your needs */
  word-wrap: break-word; /* Breaks long words if they exceed the cell width */
  overflow-wrap: break-word; /* A more modern alternative to word-wrap */
}

thead th {
  background-color: #f2f2f2;
  position: sticky;
  top: 0;
  z-index: 10;
  font-weight: bold;
  text-transform: uppercase;
}

tbody th {
  background-color: #f2f2f2;
  position: sticky;
  left: 0;
  z-index: 5;
  border-right: 1px solid #ccc;
}

td ul {
  margin: 0;
  padding-left: 1em;
}

tr:nth-child(even) { background-color: #f8f8f8; }


</style>

{%- set results = model.validate() %}
{%- set CATEGORIES = model.validation.rules %}

<title>System Analysis Layer: Modeling Rules Compliance Report</title>
</head>
<body>
<h1>System Analysis Layer: Modeling Rules Compliance Report</h1>
<p>
  The report provides an assessment of adherence to Modeling Rules and Best Practices by the contents of the System Analysis model layer.
</p>

{% macro show_compliance_score(passed, total) %}
  {# This macro shows compliance score and conditionally colors it: if value is below 30% it will be red, between 30 and 70 % it will be orange, above 70 % green; #}
  {# It is also possible that total is 0, in this case it will return "not applicable" in gray color #}
  {% if total > 0 %}
    {% set compliance_score = (passed / total * 100)|round(1) %}
    {% set compliance = compliance_score | string + "%" %}
    {% set color = "#bc2604" if compliance_score < 30 else ("#ae930d" if compliance_score < 70 else "#0a6600") %}
    <span style="color:{{ color }}">{{ compliance }} <small>{{ "({} / {})".format(passed, total) }}</small></span>
  {% else %}
    <span style="color:#ccc">not applicable</span>
  {% endif %}
{% endmacro %}

